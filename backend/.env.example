APP_NAME="Baboon Technologies API"
ENVIRONMENT="development"
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
EDGAR_USER_AGENT=your_email@example.com
FRED_API_KEY=your_key_here
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# --- LLM provider ---
# Compatibility: agent requires structured output (router) + tool calling (plan_node).
#
# FULLY COMPATIBLE — recommended:
#   openai           -> LLM_MODEL=gpt-4o-mini                    (OPENAI_API_KEY)
#   anthropic        -> LLM_MODEL=claude-sonnet-4-6              (ANTHROPIC_API_KEY)
#   xai              -> LLM_MODEL=grok-3                         (XAI_API_KEY)
#   bedrock          -> LLM_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0 (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_DEFAULT_REGION)
#
# COMPATIBLE WITH KNOWN QUIRKS — use these models specifically:
#   cohere           -> LLM_MODEL=command-r-plus-08-2024         (COHERE_API_KEY)
#     IMPORTANT: use command-r-plus-08-2024 (v1 API). Avoid command-a-03-2025 (v2):
#     structured output unreliable, streaming crashes on billed_units=None.
#     Tool parameters must not have null defaults (int/float, not int|None).
#   google_genai     -> LLM_MODEL=gemini-2.0-flash               (GOOGLE_API_KEY)
#   google_vertexai  -> LLM_MODEL=gemini-2.0-flash               (GCP application default credentials)
#     IMPORTANT: Gemini requires strict Human/AI message alternation.
#     Multi-turn tool loops may fail if consecutive same-role messages appear.
#   groq             -> LLM_MODEL=llama-3.3-70b-versatile        (GROQ_API_KEY)
#   mistralai        -> LLM_MODEL=mistral-large-latest           (MISTRAL_API_KEY)
#   fireworks        -> LLM_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct (FIREWORKS_API_KEY)
#   together         -> LLM_MODEL=meta-llama/Llama-3-70b-chat-hf (TOGETHER_API_KEY)
#     NOTE: fireworks/together use OpenAI-compatible APIs and generally work,
#     but open-source models vary — structured output may be unreliable on smaller models.
#
# NOT COMPATIBLE — missing structured output and/or tool calling:
#   huggingface      -> LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3 (HUGGINGFACEHUB_API_TOKEN)
#   ollama           -> LLM_MODEL=llama3.2                       (no key required)
#     NOTE: huggingface/ollama lack reliable structured output and tool calling.
#     Router and plan_node will fail.
OPENAI_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here
GOOGLE_API_KEY=your_key_here
GROQ_API_KEY=your_key_here
MISTRAL_API_KEY=your_key_here
COHERE_API_KEY=your_key_here
# FIREWORKS_API_KEY=your_key_here
# TOGETHER_API_KEY=your_key_here
# XAI_API_KEY=your_key_here
# HUGGINGFACEHUB_API_TOKEN=your_key_here
# AWS_ACCESS_KEY_ID=your_key_here
# AWS_SECRET_ACCESS_KEY=your_key_here
# AWS_DEFAULT_REGION=us-east-1
# --- Per-node model allocation ---
# Each node can override provider and model independently.
# Defaults shown below — comment out to use the default.
ROUTER_LLM_PROVIDER=anthropic
ROUTER_LLM_MODEL=claude-haiku-4-5-20251001
PLAN_LLM_PROVIDER=openai
PLAN_LLM_MODEL=gpt-4.1
REACT_LLM_PROVIDER=openai
REACT_LLM_MODEL=gpt-4.1
RESPONSE_LLM_PROVIDER=anthropic
RESPONSE_LLM_MODEL=claude-haiku-4-5-20251001
JUDGE_LLM_PROVIDER=openai
JUDGE_LLM_MODEL=gpt-4o-mini
SCRAPE_LLM_PROVIDER=groq
SCRAPE_LLM_MODEL=llama-3.3-70b-versatile
# LLM_MAX_TOKENS=4096
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=api_key
LANGSMITH_PROJECT="baboon-financial-analyst"
